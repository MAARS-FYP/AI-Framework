# Copy this file to .env and adjust values for deployment.
# CLI args still override these values.

# Runtime mode: hardware | simulate
MODE=hardware

# IPC mode: direct | shm
IPC_MODE=shm

# Worker + Rust shared socket
SOCKET_PATH=/tmp/maars_infer.sock
SAMPLE_RATE_HZ=125000000

# SHM configuration (used when IPC_MODE=shm)
SHM_NAME=maars_iq_ring
SHM_SLOTS=8
SHM_SLOT_CAPACITY=8192
WORKER_SHM_CREATE=1
WORKER_SHM_UNLINK_ON_EXIT=1

# Python worker model/scalers
CHECKPOINT_PATH=./checkpoints/best_model.pt
SCALERS_PATH=./checkpoints/scalers.joblib
WORKER_DEVICE=auto

# Python executable
# PYTHON_BIN=./.venv/bin/python

# Hardware mode I/O
UART_PORT=/dev/ttyUSB0
UART_BAUD=115200
UDP_BIND=127.0.0.1:5000

# Simulation mode controls
SIMULATE_CYCLES=0
SIMULATE_INTERVAL_MS=200
SIMULATE_SAMPLES=4096
SIMULATE_POWER_LNA=-35.2
SIMULATE_POWER_PA=-22.8

# Rust-side SHM cleanup (set 1 only if worker is NOT unlinking)
RUST_CLEANUP_SHM_ON_EXIT=0

# Launcher wait timeout for worker socket readiness
SOCKET_WAIT_TIMEOUT_SEC=30
